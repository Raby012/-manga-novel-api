# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,https://YOUR-LOVABLE-URL.lovableproject.com

# ─── Cloudflare Bypass ────────────────────────────────────────────────────────
# OPTION A — Residential Proxy (easiest)
# Get free at webshare.io
PROXY_URL=http://username:password@proxy.webshare.io:80

# OPTION B — FlareSolverr (most powerful)
# Deploy ghcr.io/flaresolverr/flaresolverr:latest on Railway
FLARESOLVERR_URL=http://flaresolverr.railway.internal:8191
