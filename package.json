{
  "name": "manga-novel-api",
  "version": "2.0.0",
  "description": "Proxy API for Manga/Manhwa/Manhua and Light Novels. Bypasses CORS and Cloudflare using got-scraping.",
  "main": "dist/src/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/src/server.js",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@consumet/extensions": "^0.2.8",
    "cheerio": "^1.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "got-scraping": "^4.0.4",
    "helmet": "^7.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "tsx": "^4.15.7",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
